/*
 * Stratus Pro nRF9151 device overlay configuration for LIS2DH sensor connected to QWIIC port
 *
 */
&i2c2 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
	lis2dh: lis2dh@18 {
		compatible = "st,lis2dh";
		reg = <0x18>;
		irq-gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
		disconnect-sdo-sa0-pull-up;
	};
};
